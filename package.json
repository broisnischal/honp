{
  "name": "payment-app",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "typecheck": "wrangler types && react-router typegen && tsc --noEmit",
    "build": "react-router build",
    "preview": "react-router build && vite preview",
    "dev:wrangler": "wrangler dev",
    "deploy": "react-router build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create payment-app-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "up-fetch": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@react-router/dev": "^7.14.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "wrangler": "^4.80.0"
  }
}
